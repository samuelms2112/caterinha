<%- include('_header', { pageTitle: 'Foto', aluno: aluno, showBack: true }) %>

<div class="portal-section-title">FOTO DO ALUNO</div>

<div class="portal-card" style="text-align:center;padding:28px 16px">
  <% if (aluno.foto && aluno.foto !== 'default.png') { %>
    <img src="/uploads/<%= aluno.foto %>" alt="Foto" class="foto-grande">
  <% } else { %>
    <div class="foto-placeholder-grande">
      <%= aluno.nome ? aluno.nome.charAt(0).toUpperCase() : '?' %>
    </div>
  <% } %>
  <p style="margin-top:14px;font-weight:600;font-size:15px"><%= aluno.nome %></p>
  <p style="color:#666;font-size:13px;margin-top:4px">Matrícula: <%= aluno.matricula %></p>
  <p style="color:#888;font-size:12px;margin-top:14px">Para atualizar sua foto, compareça à secretaria da instituição.</p>
</div>

<%- include('_footer') %>
