<%- include('_header', { pageTitle: 'NSA — ALUNO', aluno: aluno, showBack: false }) %>

<!-- Aviso -->
<div class="portal-aviso">
  <div class="aviso-title">AVISO</div>
  <p><%= content.aviso %></p>
</div>

<!-- Habilitação -->
<div class="portal-section-title">SELECIONE A HABILITAÇÃO</div>
<div class="portal-card portal-card--select">
  <span><%= aluno.curso %></span>
  <span class="card-arrow">&#9660;</span>
</div>

<!-- Dados da classe -->
<div class="portal-section-title">DADOS DA CLASSE SELECIONADA</div>
<div class="portal-card portal-card--data">
  <p><strong>RM:</strong> <%= aluno.matricula %></p>
  <p><strong>Semestre OC:</strong> 1° SEMESTRE &nbsp;&nbsp; <strong>Ano OC:</strong> <%= new Date().getFullYear() %></p>
  <p><strong>Módulo/Série Atual:</strong> <%= aluno.periodo %></p>
  <p><strong>Turma:</strong> TURMA A</p>
  <p><strong>Grupo do Componente:</strong> &nbsp;</p>
  <p><strong>Situação da Matrícula:</strong> CURSANDO</p>
  <p><strong>Validade:</strong> <%= aluno.validade %></p>
</div>

